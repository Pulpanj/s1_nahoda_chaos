digraph blechy {
    rankdir = TB;
    fontsize=7;
    node [fontsize=6 size=3];
    edge [fontsize=6];
    0[label="nastav\nK=0" color=green];
    K[label="další hod\nK=K+1"color=blue];
    1[label="1,3,5"];
    6[label="6\nkonec" color=red];
    2[label="2,4"];

    0  -> K[label="P=1"];
    K  -> 6[label="P=1/6" color=red];
    K->2[label="P=1/3"];
    K  -> 1[label="P=1/2"];
    1->0[label="P=1"];
    2->K[label="P=1/2" color=blue];
    2->1[label="P=1/2" color=green];
